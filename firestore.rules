rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────
    // HELPERS
    // ─────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function hasFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // ─────────────────────────────────────────────────────
    // USERS — authenticated read, self-only write
    // ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId) && hasFields(['email', 'role']);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────
    // GIGS (CAMPAIGNS) — PUBLIC read, brand-owned write
    // Public read so landing page & Opportunities page work
    // for visitors who are not logged in.
    //
    // SCHEMA: { title, brandId, brandEmail, brandName, status, reward, createdAt }
    // KEY RULE: brandId MUST equal the Firebase UID of the creator.
    //   → This guarantees `where('brandId','==', uid)` always works.
    // ─────────────────────────────────────────────────────
    match /gigs/{gigId} {
      allow read: if true;   // public – anyone can browse campaigns

      allow create: if isAuth()
        && request.resource.data.brandId == request.auth.uid
        && hasFields(['title', 'brandId', 'brandName', 'status', 'reward', 'createdAt']);

      allow update, delete: if isAuth()
        && (resource.data.brandId == request.auth.uid || isAdmin());
    }

    // ─────────────────────────────────────────────────────
    // EVENTS — PUBLIC read, host-owned write
    //
    // SCHEMA: { name, hostId, hostName, createdAt }
    // KEY RULE: hostId MUST equal the Firebase UID of the creator.
    // ─────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;   // public – visitors can see campus events

      allow create: if isAuth()
        && request.resource.data.hostId == request.auth.uid
        && hasFields(['name', 'hostId', 'hostName', 'createdAt']);

      allow update, delete: if isAuth()
        && (resource.data.hostId == request.auth.uid || isAdmin());
    }

    // ─────────────────────────────────────────────────────
    // GIG APPLICATIONS (sub-collection)
    // ─────────────────────────────────────────────────────
    match /gigs/{gigId}/applications/{appId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && (request.resource.data.studentId == request.auth.uid || request.resource.data.creatorId == request.auth.uid);
      allow update: if isAuth();   // brand accepts/rejects
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────
    // APPLICATIONS (top-level fallback collection)
    // ─────────────────────────────────────────────────────
    match /applications/{appId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────
    // PROPOSALS
    // ─────────────────────────────────────────────────────
    match /proposals/{proposalId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────
    // WALLETS — allow read & write for app functionality
    // ─────────────────────────────────────────────────────
    match /wallets/{userId} {
      allow read, write: if true;
    }

    // ─────────────────────────────────────────────────────
    // TRANSACTIONS — allow read & write for payment records
    // ─────────────────────────────────────────────────────
    match /transactions/{transactionId} {
      allow read, write: if true;
    }

    // ─────────────────────────────────────────────────────
    // ALLOCATIONS — allow read & write for campaigns
    // ─────────────────────────────────────────────────────
    match /allocations/{allocationId} {
      allow read, write: if true;
    }

    // ─────────────────────────────────────────────────────
    // BLOGS
    // ─────────────────────────────────────────────────────
    match /blogs/{document=**} {
      allow read: if true;
      allow write: if isAuth() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      );
    }

    // ─────────────────────────────────────────────────────
    // CAMPAIGNS & ALLOCATIONS
    // ─────────────────────────────────────────────────────
    match /campaigns/{id} {
      allow read: if true;
      allow write: if isAuth();

      match /applications/{appId} {
        allow read: if isAuth();
        allow create: if isAuth() 
          && (request.resource.data.creatorId == request.auth.uid || request.resource.data.studentId == request.auth.uid);
        allow update: if isAuth();
        allow delete: if isAdmin();
      }
    }
    match /campaignAllocations/{id} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ─────────────────────────────────────────────────────
    // NOTIFICATIONS
    // ─────────────────────────────────────────────────────
    match /notifications/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
      allow delete: if isAuth();
    }

    // ─────────────────────────────────────────────────────
    // SITE SETTINGS, PAST EVENTS, TESTIMONIALS
    // ─────────────────────────────────────────────────────
    match /site_settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /past_events/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /testimonials/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────
    // RATING REQUESTS
    // ─────────────────────────────────────────────────────
    match /ratingRequests/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ─────────────────────────────────────────────────────
    // DISPUTES
    // ─────────────────────────────────────────────────────
    match /disputes/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────
    // PLATFORM REVIEWS
    // ─────────────────────────────────────────────────────
    match /platformReviews/{id} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────
    // SUPPORT TICKETS
    // ─────────────────────────────────────────────────────
    match /support_tickets/{id} {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
// Force rules deployment v3
